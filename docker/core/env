# App Configuration
BRAND_NAME=UMAXICA
# Ruby Configuration
RUBY_YJIT_ENABLE=1
RUBY_PATH=/usr/local/bin/ruby
BUNDLE_JOBS=8
BUNDLE_PATH=vendor/bundle
BUNDLE_FORCE_RUBY_PLATFORM=false
COLORTERM=truecolor
# Rails Configuration
RAILS_ENV=development
RACK_ENV=development
PORT=3000
BINDING=0.0.0.0
OPEN_TELEMETRY=false
# Node Environment
NODE_ENV=development
# Region
# GLOBAL_MODE=true
